#include <stdio.h>
#define MAX 10

// Function to input matrix
void inputMatrix(int mat[MAX][MAX], int r, int c) {
    int i, j;
    printf("Enter elements:\n");
    for(i = 0; i < r; i++) {
        for(j = 0; j < c; j++) {
            scanf("%d", &mat[i][j]);
        }
    }
}

// Function to display matrix
void displayMatrix(int mat[MAX][MAX], int r, int c) {
    int i, j;
    for(i = 0; i < r; i++) {
        for(j = 0; j < c; j++) {
            printf("%d\t", mat[i][j]);
        }
        printf("\n");
    }
}

// Matrix Addition
void addMatrix(int A[MAX][MAX], int B[MAX][MAX], int r, int c) {
    int i, j, result[MAX][MAX];

    for(i = 0; i < r; i++) {
        for(j = 0; j < c; j++) {
            result[i][j] = A[i][j] + B[i][j];
        }
    }

    printf("\nResult of Addition:\n");
    displayMatrix(result, r, c);
}

// Matrix Multiplication
void multiplyMatrix(int A[MAX][MAX], int B[MAX][MAX], int r1, int c1, int c2) {
    int i, j, k, result[MAX][MAX];

    for(i = 0; i < r1; i++) {
        for(j = 0; j < c2; j++) {
            result[i][j] = 0;
            for(k = 0; k < c1; k++) {
                result[i][j] += A[i][k] * B[k][j];
            }
        }
    }

    printf("\nResult of Multiplication:\n");
    displayMatrix(result, r1, c2);
}

// Matrix Transpose
void transposeMatrix(int mat[MAX][MAX], int r, int c) {
    int i, j, trans[MAX][MAX];

    for(i = 0; i < r; i++) {
        for(j = 0; j < c; j++) {
            trans[j][i] = mat[i][j];
        }
    }

    displayMatrix(trans, c, r);
}

int main() {
    int A[MAX][MAX], B[MAX][MAX];
    int r1, c1, r2, c2, choice;

    // Input Matrix A
    printf("Enter rows and columns of Matrix A: ");
    scanf("%d %d", &r1, &c1);
    inputMatrix(A, r1, c1);

    // Input Matrix B
    printf("\nEnter rows and columns of Matrix B: ");
    scanf("%d %d", &r2, &c2);
    inputMatrix(B, r2, c2);

    // Menu
    printf("\n===== MENU =====\n");
    printf("1. Addition\n");
    printf("2. Multiplication\n");
    printf("3. Transpose of Matrix A\n");
    printf("4. Transpose of Matrix B\n");
    printf("Enter your choice: ");
    scanf("%d", &choice);

    switch(choice) {
        case 1:
            if(r1 == r2 && c1 == c2)
                addMatrix(A, B, r1, c1);
            else
                printf("Addition not possible!\n");
            break;

        case 2:
            if(c1 == r2)
                multiplyMatrix(A, B, r1, c1, c2);
            else
                printf("Multiplication not possible!\n");
            break;

        case 3:
            printf("\nTranspose of Matrix A:\n");
            transposeMatrix(A, r1, c1);
            break;

        case 4:
            printf("\nTranspose of Matrix B:\n");
            transposeMatrix(B, r2, c2);
            break;

        default:
            printf("Invalid choice!\n");
    }

    return 0;
}
